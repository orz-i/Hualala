{
  "name": "hualala",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.16.0",
  "scripts": {
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:e2e:admin": "node tooling/scripts/run-playwright-suite.mjs admin test tests/e2e/admin-smoke.spec.ts",
    "test:e2e:creator": "node tooling/scripts/run-playwright-suite.mjs creator test tests/e2e/creator-smoke.spec.ts",
    "test:e2e:phase1": "node tooling/scripts/run-playwright-suite.mjs all test tests/e2e/phase1-acceptance.spec.ts",
    "test:e2e:phase2:collaboration": "node tooling/scripts/run-playwright-suite.mjs all test tests/e2e/phase2-collaboration.spec.ts",
    "test:e2e:phase2:preview": "node tooling/scripts/run-playwright-suite.mjs all test tests/e2e/phase2-preview.spec.ts",
    "test:e2e:phase2:audio": "node tooling/scripts/run-playwright-suite.mjs all test tests/e2e/phase2-audio.spec.ts",
    "test:e2e:phase2:asset-reuse": "node tooling/scripts/run-playwright-suite.mjs all test tests/e2e/phase2-asset-reuse.spec.ts",
    "test:e2e:phase2": "node tooling/scripts/run-playwright-suite.mjs all test tests/e2e/phase2-collaboration.spec.ts tests/e2e/phase2-preview.spec.ts tests/e2e/phase2-audio.spec.ts tests/e2e/phase2-asset-reuse.spec.ts",
    "test:e2e:admin:real": "node tooling/scripts/run-playwright-suite.mjs admin-real test tests/e2e/admin-real-smoke.spec.ts",
    "test:e2e:creator:real": "node tooling/scripts/run-playwright-suite.mjs creator-real test tests/e2e/creator-real-smoke.spec.ts",
    "test:e2e:phase1:real": "node tooling/scripts/run-playwright-suite.mjs all-real test tests/e2e/phase1-real-acceptance.spec.ts",
    "test:e2e:phase2:preview:real": "node tooling/scripts/run-playwright-suite.mjs all-real test tests/e2e/phase2-preview-real-smoke.spec.ts",
    "test:e2e:phase2:audio:real": "node tooling/scripts/run-playwright-suite.mjs all-real test tests/e2e/phase2-audio-real-smoke.spec.ts",
    "test:e2e:phase2:real": "corepack pnpm run test:e2e:phase2:preview:real && corepack pnpm run test:e2e:phase2:audio:real",
    "test:tooling": "node --test tooling/scripts/demo_seed.test.mjs tooling/scripts/backend_seed.test.mjs tooling/scripts/foundation_baseline_docs.test.mjs tooling/scripts/foundation_shared_truth_guard.test.mjs tooling/scripts/mock_connect_fixture_modules.test.mjs tooling/scripts/mock_connect_fail_closed.test.mjs tooling/scripts/i18n_key_parity_check.test.mjs tooling/scripts/phase1_ci_real_acceptance.test.mjs tooling/scripts/phase2_postgres_ci.test.mjs tooling/scripts/run-dev-real.test.mjs tooling/scripts/run-playwright-suite.test.mjs",
    "demo:seed": "node tooling/scripts/demo_seed.mjs",
    "demo:seed:backend": "node tooling/scripts/backend_seed.mjs",
    "db:up": "node tooling/scripts/docker_compose.mjs up -d",
    "db:down": "node tooling/scripts/docker_compose.mjs down -v",
    "db:migrate": "go run ./apps/backend/cmd/migrate",
    "db:bootstrap-dev": "go run ./apps/backend/cmd/bootstrapdev",
    "dev:real": "node tooling/scripts/run-dev-real.mjs",
    "dev:real:seed": "corepack pnpm run demo:seed:backend",
    "dev": "turbo run dev",
    "proto:lint": "node tooling/scripts/run-buf.mjs lint",
    "proto:gen": "node tooling/scripts/run-buf.mjs generate",
    "i18n:check": "node tooling/scripts/i18n_key_parity_check.mjs"
  },
  "devDependencies": {
    "@bufbuild/buf": "^1.66.1",
    "@playwright/test": "^1.58.2",
    "pnpm": "10.16.0",
    "turbo": "^2.5.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@bufbuild/buf"
    ]
  }
}
